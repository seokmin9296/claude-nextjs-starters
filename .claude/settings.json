{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$f = [Console]::In.ReadToEnd() | & 'C:\\ProgramData\\chocolatey\\bin\\jq.exe' -r '.tool_input.file_path // .tool_response.filePath // empty'; if ($f -and ($f -match '\\.(ts|tsx|js|jsx|json|css|scss|md)$')) { npx prettier --write $f 2>$null }; exit 0",
            "timeout": 30,
            "statusMessage": "Prettier 포맷팅 중..."
          }
        ]
      }
    ]
  }
}
